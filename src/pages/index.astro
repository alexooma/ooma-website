---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OOMA">
  <style>
    /*
     * 2-column grid:
     *   col 1 (244px): studio-info (top) | links (bottom)
     *   col 2 (1fr):   video (top)       | projects (bottom)
     *
     * DOM order = mobile stacking: studio-info → video → projects → links
     */
    .main {
      display: grid;
      grid-template-columns: 244px 1fr;
      grid-template-rows: auto auto;
      column-gap: 30px;
      row-gap: 20px;
    }

    .studio-info {
      grid-column: 1;
      grid-row: 1;
      align-self: start;
      display: flex;
      flex-direction: column;
      gap: 25px;
    }

    .landing-video {
      grid-column: 2;
      grid-row: 1;
      width: 100%;
      height: auto;
      display: block;
      border-radius: 4px;
    }

    .projects {
      grid-column: 2;
      grid-row: 2;
      display: flex;
      flex-direction: row;
      gap: 30px;
    }

    .links {
      grid-column: 1;
      grid-row: 2;
      align-self: end;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    /* Studio info */
    .studio-title {
      font-family: 'Paragon', serif;
      font-size: 35px;
      font-weight: 400;
      margin: 0;
      color: white;
      line-height: 1.1;
    }

    .studio-desc {
      font-family: 'Share Tech Mono', monospace;
      font-size: 18px;
      margin: 0;
      color: white;
      line-height: 1.4;
    }

    /* Links */
    .nav-link {
      font-family: 'Share Tech Mono', monospace;
      font-size: 15px;
      color: white;
      text-decoration: none;
    }

    .nav-link:hover { text-decoration: underline; }

    .contact {
      font-family: 'Share Tech Mono', monospace;
      font-size: 15px;
      color: #808080;
    }

    /* Projects */
    .project {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .project-name {
      font-family: 'Paragon', serif;
      font-size: 22px;
      font-weight: 400;
      margin: 0;
      color: white;
      text-decoration: none;
    }

    .project-name:hover { text-decoration: underline; }

    .project-desc {
      font-family: 'Share Tech Mono', monospace;
      font-size: 14px;
      margin: 0;
      color: white;
    }

    .project-achievement {
      font-family: 'Share Tech Mono', monospace;
      font-size: 13px;
      margin: 0;
      color: white;
      opacity: 0.6;
    }

    @media (max-width: 600px) {
      .main {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .landing-video { max-height: 240px; width: auto; max-width: 100%; }
      .studio-title  { font-size: 26px; }
      .studio-desc   { font-size: 15px; }
      .projects      { flex-direction: column; gap: 16px; }
    }
  </style>

  <!--
    DOM order = mobile order: studio-info → video → projects → links
    Desktop: CSS Grid places them in the correct 2-column layout.
  -->
  <main class="main">

    <div class="studio-info">
      <p class="studio-title">AI character studio</p>
      <p class="studio-desc">We give birth and grow AI-native social characters</p>
    </div>

    <video
      class="landing-video"
      src="assets/landing.mp4"
      autoplay
      muted
      loop
      playsinline
    ></video>

    <div class="projects">
      <div class="project">
        <a href="https://ted.ooma.live/" class="project-name">@ted</a>
        <p class="project-desc">Social AI companion app</p>
        <p class="project-achievement">Top 50 FR App Store, Entertainment</p>
      </div>
      <div class="project">
        <a href="https://www.tiktok.com/@talkingwoody" class="project-name">@woody</a>
        <p class="project-desc">Autonomous AI livestreamer on tiktok live</p>
        <p class="project-achievement">Top 1% TikTok Live</p>
      </div>
    </div>

    <div class="links">
      <a href="/manifesto" class="nav-link">Our manifesto</a>
      <a href="/terms-of-services" class="nav-link">Terms of Service</a>
      <span class="contact">contact@ooma.live</span>
    </div>

  </main>
</Layout>
