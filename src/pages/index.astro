<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Pridi:wght@300&display=swap" rel="stylesheet">
    <style>
      @font-face {
        font-family: 'Paragon';
        src: url('/fonts/Paragon-Regular.otf') format('opentype');
        font-weight: 400;
        font-style: normal;
      }
      @font-face {
        font-family: 'Paragon';
        src: url('/fonts/Paragonitalic-Regular.otf') format('opentype');
        font-weight: 400;
        font-style: italic;
      }
    </style>
    <title>OOMA</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
      }

      body {
        background-color: #141415;
        color: white;
        font-family: 'Share Tech Mono', monospace;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* ── Desktop: CSS grid ── */
      .main-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto 1fr auto auto;
        width: 100%;
        max-width: 1265px;
        min-height: 100vh;
        padding: 80px 60px;
        column-gap: 30px;
        row-gap: 55px;
      }

      .nav         { grid-column: 1; grid-row: 4; align-self: end; }
      .logo-container { grid-column: 1; grid-row: 1; }
      .studio-info { grid-column: 1; grid-row: 2; align-self: start; }
      .profiles    { grid-column: 1; grid-row: 3; align-self: start; }
      .landing-video {
        grid-column: 2;
        grid-row: 1 / 5;
        align-self: center;
        justify-self: center;
        width: 100%;
        max-width: 544px;
        height: auto;
        display: block;
        border-radius: 4px;
      }

      /* ── Logo ── */
      .logo-container {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 21px;
      }

      .logo { width: 96px; height: auto; }

      .company-name {
        font-family: 'Paragon', serif;
        font-size: 50px;
        font-weight: 400;
        color: white;
        line-height: 1;
      }

      /* ── Studio info ── */
      .studio-info {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .studio-title {
        font-family: 'Paragon', serif;
        font-size: 50px;
        font-weight: 400;
        margin: 0;
        color: white;
        line-height: 1.1;
      }

      .studio-description {
        font-family: 'Share Tech Mono', monospace;
        font-size: 20px;
        margin: 0;
        color: white;
      }

      /* ── Profiles ── */
      .profiles {
        display: flex;
        flex-direction: column;
        gap: 40px;
      }

      .profile {
        display: flex;
        flex-direction: column;
        gap: 5px;
      }

      .profile-name {
        font-family: 'Paragon', serif;
        font-size: 25px;
        font-weight: 400;
        margin: 0;
        color: white;
        text-decoration: none;
      }

      .profile-name:hover { text-decoration: underline; }

      .profile-description {
        font-family: 'Share Tech Mono', monospace;
        font-size: 15px;
        margin: 0;
        color: white;
      }

      .profile-achievement {
        font-family: 'Pridi', serif;
        font-size: 14px;
        font-weight: 300;
        margin: 0;
        color: white;
        opacity: 0.7;
      }

      /* ── Nav ── */
      .nav {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
      }

      .nav-links {
        display: flex;
        flex-direction: row;
        gap: 20px;
      }

      .nav-link {
        font-family: 'Share Tech Mono', monospace;
        font-size: 20px;
        color: white;
        text-decoration: none;
      }

      .nav-link.active { color: #FFE100; }
      .nav-link:hover { text-decoration: underline; }

      .contact-info {
        font-family: 'Share Tech Mono', monospace;
        font-size: 20px;
        color: white;
      }

      /* ── Mobile ── */
      @media (max-width: 900px) {
        body {
          align-items: flex-start;
        }

        .main-content {
          grid-template-columns: 1fr;
          grid-template-rows: auto;
          min-height: auto;
          padding: 36px 24px;
          row-gap: 32px;
        }

        /* nav on top, then logo, studio, video, profiles */
        .nav           { grid-column: 1; grid-row: 1; align-self: auto; }
        .logo-container { grid-column: 1; grid-row: 2; }
        .studio-info   { grid-column: 1; grid-row: 3; align-self: auto; }
        .landing-video { grid-column: 1; grid-row: 4; align-self: auto; justify-self: auto; max-width: 100%; }
        .profiles      { grid-column: 1; grid-row: 5; align-self: auto; }

        .nav {
          flex-direction: row;
          align-items: center;
        }

        .studio-title  { font-size: 32px; }
        .company-name  { font-size: 36px; }
      }

      @media (max-width: 480px) {
        .main-content { padding: 28px 20px; row-gap: 28px; }
        .studio-title, .company-name { font-size: 26px; }
        .studio-description, .nav-link, .contact-info { font-size: 15px; }
        .profile-description { font-size: 13px; }
        .profile-achievement  { font-size: 12px; }
        .logo { width: 64px; }
        .profiles { gap: 28px; }
      }
    </style>
  </head>
  <body>
    <div class="main-content">

      <div class="logo-container">
        <img src="assets/logo_white.png" alt="OOMA Logo" class="logo" />
        <span class="company-name">ooma</span>
      </div>

      <div class="studio-info">
        <p class="studio-title">AI character studio</p>
        <p class="studio-description">We give birth and grow AI-native social characters</p>
      </div>

      <video
        class="landing-video"
        src="assets/landing.mp4"
        autoplay
        muted
        loop
        playsinline
      ></video>

      <div class="profiles">
        <div class="profile">
          <a href="https://ted.ooma.live/" class="profile-name">@Ted</a>
          <p class="profile-description">Social AI companion app</p>
          <p class="profile-achievement">Top 50 FR App Store, Entertainment</p>
        </div>
        <div class="profile">
          <a href="https://www.tiktok.com/@talkingwoody" class="profile-name">@woody</a>
          <p class="profile-description">Autonomous AI livestreamer on tiktok live</p>
          <p class="profile-achievement">Top 1% TikTok Live</p>
        </div>
      </div>

      <nav class="nav">
        <div class="nav-links">
          <a href="/" class="nav-link active">Home</a>
          <a href="/manifesto" class="nav-link">Manifesto</a>
        </div>
        <span class="contact-info">contact@ooma.live</span>
      </nav>

    </div>
  </body>
</html>
