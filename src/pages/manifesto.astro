---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OOMA — Manifesto">
  <style>
    /*
     * 2-column grid:
     *   col 1 (406px): section-info (top) | contact (bottom)
     *   col 2 (1fr):   body text (spans both rows)
     *
     * DOM order = mobile stacking: section-info → body-text → contact
     */
    .main {
      display: grid;
      grid-template-columns: 406px 1fr;
      grid-template-rows: auto auto;
      column-gap: 30px;
      row-gap: 20px;
    }

    .section-info {
      grid-column: 1;
      grid-row: 1;
      align-self: start;
      display: flex;
      flex-direction: column;
      gap: 25px;
    }

    .body-text {
      grid-column: 2;
      grid-row: 1 / 3;
      align-self: start;
      display: flex;
      flex-direction: column;
      gap: 40px;
    }

    .contact-row {
      grid-column: 1;
      grid-row: 2;
      align-self: end;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    /* Left column */
    .section-label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 14px;
      margin: 0;
      color: white;
    }

    .section-tagline {
      font-family: 'Paragon', serif;
      font-size: 40px;
      font-weight: 400;
      margin: 0;
      color: white;
      line-height: 1.15;
    }

    .contact {
      font-family: 'Share Tech Mono', monospace;
      font-size: 15px;
      color: #808080;
    }

    /* Right column */
    .text-block {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .text-title {
      font-family: 'Paragon', serif;
      font-size: 22px;
      font-weight: 400;
      margin: 0;
      color: white;
      line-height: 1.2;
    }

    .text-body {
      font-family: 'Share Tech Mono', monospace;
      font-size: 15px;
      margin: 0;
      color: white;
      line-height: 1.6;
    }

    .text-closing {
      font-family: 'Share Tech Mono', monospace;
      font-size: 15px;
      margin: 0;
      color: white;
      line-height: 1.6;
    }

    /* Links footer (mirrors homepage) */
    .nav-link {
      font-family: 'Share Tech Mono', monospace;
      font-size: 15px;
      color: white;
      text-decoration: none;
    }

    .nav-link:hover { text-decoration: underline; }

    /* Medium screens */
    @media (max-width: 1100px) {
      .section-tagline { font-size: 32px; }
    }

    /* Mobile */
    @media (max-width: 600px) {
      .main {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .section-tagline { font-size: 26px; }
      .text-title      { font-size: 18px; }
    }
  </style>

  <!--
    DOM order = mobile order: section-info → body-text → contact
  -->
  <main class="main">

    <div class="section-info">
      <p class="section-label">Manifesto</p>
      <p class="section-tagline">AI characters are the next interface that gathers humans around.</p>
    </div>

    <div class="body-text">
      <div class="text-block">
        <p class="text-title">How people will hang out in the post-AI world.</p>
        <p class="text-body">We are building the future social interface, one that is as entertaining as it is alive. The real magic happens when AI makes human-to-human moments richer, funnier, and more electric. A shared experience.</p>
      </div>
      <div class="text-block">
        <p class="text-title">The next AI characters interface is live, visual and shared.</p>
        <p class="text-body">Characters that perform and react in real time. Audiences that gather, argue, and build stories together.</p>
      </div>
      <div class="text-block">
        <p class="text-title">We are building the platform that makes all of it possible.</p>
        <p class="text-body">We are builders and artists working at the intersection of emotional intelligence, real-time interaction, and AI embodiment. We prototype fast, deploy in the wild, and learn from real social dynamics.</p>
      </div>
      <p class="text-closing">If this future excites you, we would love to hear from you.<br>— Alex, Kevin, and the OOMA team</p>
    </div>

    <div class="contact-row">
      <a href="/manifesto" class="nav-link">Our manifesto</a>
      <span class="contact">contact@ooma.live</span>
    </div>

  </main>
</Layout>
